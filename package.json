{
    "private": true,
    "version": "0.1.2",
    "main": "dist/main.js",
    "type": "module",
    "scripts": {
        "start": "node .",
        "predev": "pnpm clean && prisma generate",
        "dev": "tsc-watch --onSuccess \"node .\"",
        "test": "pnpm build",
        "prebuild": "pnpm clean && prisma generate",
        "build": "tsc --build",
        "clean": "rimraf dist",
        "lint": "eslint --fix \"src/**/*.ts\"",
        "format": "prettier --write \"src/**/*.ts\"",
        "v:patch": "npm version patch -m \"chore(release): %s\" --sign-git-tag",
        "v:minor": "npm version minor -m \"chore(release): %s\" --sign-git-tag",
        "v:major": "npm version major -m \"chore(release): %s\" --sign-git-tag"
    },
    "dependencies": {
        "@prisma/adapter-better-sqlite3": "^7.8.0",
        "@prisma/client": "7.8.0",
        "@t3-oss/env-core": "^0.13.11",
        "discord.js": "^14.26.3",
        "dotenv": "^17.4.2",
        "fast-equals": "^6.0.0",
        "ms": "^2.1.3",
        "mustache": "^4.2.0",
        "pretty-ms": "^9.3.0",
        "prisma": "^7.8.0",
        "winston": "^3.19.0",
        "yaml": "^2.8.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@types/express": "^5.0.6",
        "@types/ms": "^2.1.0",
        "@types/mustache": "^4.2.6",
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "husky": "^9.1.7",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "tsc-watch": "^7.2.0",
        "typescript": "^6.0.3"
    },
    "imports": {
        "#root/*": "./dist/*.js",
        "#classes/*": "./dist/classes/*.js",
        "#lib/*": "./dist/lib/*.js",
        "#utils/*": "./dist/utils/*.js",
        "#middlewares/*": "./dist/middlewares/*.js",
        "#events/*": "./dist/events/*.js",
        "#commands/*": "./dist/commands/*.js",
        "#configs/*": "./dist/configs/*.js",
        "#addons/*": "./dist/addons/*.js"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ],
        "rules": {
            "type-enum": [
                2,
                "always",
                [
                    "chore",
                    "build",
                    "ci",
                    "docs",
                    "feat",
                    "fix",
                    "perf",
                    "refactor",
                    "revert",
                    "style",
                    "test",
                    "types",
                    "wip"
                ]
            ],
            "scope-case": [
                1,
                "always",
                "pascal-case"
            ],
            "body-max-line-length": [
                2,
                "always",
                500
            ]
        }
    },
    "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@prisma/client",
            "@prisma/engines",
            "better-sqlite3",
            "esbuild",
            "prisma"
        ]
    }
}
