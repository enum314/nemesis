{
    "private": true,
    "version": "0.1.1",
    "main": "dist/main.js",
    "type": "module",
    "scripts": {
        "prepare": "husky install",
        "start": "node .",
        "predev": "pnpm clean && prisma generate",
        "dev": "tsc-watch --onSuccess \"node .\"",
        "test": "pnpm build",
        "prebuild": "pnpm clean && prisma generate",
        "build": "tsc --build",
        "clean": "rimraf dist",
        "lint": "eslint --fix \"src/**/*.ts\"",
        "format": "prettier --write \"src/**/*.ts\"",
        "v:patch": "npm version patch -m \"chore(release): %s\" --sign-git-tag",
        "v:minor": "npm version minor -m \"chore(release): %s\" --sign-git-tag",
        "v:major": "npm version major -m \"chore(release): %s\" --sign-git-tag"
    },
    "dependencies": {
        "@prisma/client": "6.5.0",
        "discord.js": "^14.18.0",
        "dotenv": "^16.4.7",
        "is-plain-object": "^5.0.0",
        "ms": "^2.1.3",
        "mustache": "^4.2.0",
        "pretty-ms": "^9.2.0",
        "rate-limiter-flexible": "^6.2.1",
        "winston": "^3.17.0",
        "yaml": "^2.7.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.0",
        "@commitlint/config-conventional": "^19.8.0",
        "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
        "@types/express": "^5.0.1",
        "@types/ms": "^2.1.0",
        "@types/mustache": "^4.2.5",
        "@types/node": "^22.13.13",
        "@typescript-eslint/eslint-plugin": "^8.28.0",
        "@typescript-eslint/parser": "^8.28.0",
        "eslint": "^9.23.0",
        "eslint-config-prettier": "^10.1.1",
        "eslint-plugin-prettier": "^5.2.5",
        "husky": "^9.1.7",
        "prettier": "^3.5.3",
        "prisma": "^6.5.0",
        "rimraf": "^6.0.1",
        "tsc-watch": "^6.2.1",
        "typescript": "^5.8.2"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ],
        "rules": {
            "type-enum": [
                2,
                "always",
                [
                    "chore",
                    "build",
                    "ci",
                    "docs",
                    "feat",
                    "fix",
                    "perf",
                    "refactor",
                    "revert",
                    "style",
                    "test",
                    "types",
                    "wip"
                ]
            ],
            "scope-case": [
                1,
                "always",
                "pascal-case"
            ],
            "body-max-line-length": [
                2,
                "always",
                500
            ]
        }
    },
    "packageManager": "pnpm@10.8.0+sha512.0e82714d1b5b43c74610193cb20734897c1d00de89d0e18420aebc5977fa13d780a9cb05734624e81ebd81cc876cd464794850641c48b9544326b5622ca29971"
}
